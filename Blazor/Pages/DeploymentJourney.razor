@page "/deployment-journey"
@using DomainModels.Dto
@using Blazor.Interfaces
@inject INotesApiClient NotesApiClient
@inject IHealthApiClient HealthApiClient

<h1>Victoria's Deployment Journey</h1>

<p>
    This page shows notes from my deployment learning project.
    The data comes from a Blazor WebAssembly frontend, an ASP.NET Core API backend,
    and a SQL Server database.
</p>

<h2>System Status</h2>

@if (healthStatus is null)
{
    <p>Checking backend status...</p>
}
else
{
    <div style="border: 1px solid #ccc; padding: 12px; margin-bottom: 16px; border-radius: 8px;">
        <p><strong>API status:</strong> @healthStatus.Status</p>
        <p><strong>Database:</strong> @healthStatus.Database</p>
        <p><strong>Environment:</strong> @healthStatus.Environment</p>
        <p><small>Checked at: @healthStatus.Timestamp.ToLocalTime()</small></p>
    </div>
}

<h2>Add a new note</h2>

<div>
    <label>Title</label>
    <br />
    <input @bind="newNote.Title" />
</div>

<div>
    <label>Category</label>
    <br />
    <input @bind="newNote.Category" />
</div>

<div>
    <label>Content</label>
    <br />
    <textarea @bind="newNote.Content"></textarea>
</div>

<br />

<button @onclick="CreateNoteAsync">Save note</button>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <p style="color: red;">@errorMessage</p>
}

<hr />

<h2>Notes</h2>

@if (isLoading)
{
    <p>Loading notes...</p>
}
else if (notes.Count == 0)
{
    <p>No notes found.</p>
}
else
{
    @foreach (var note in notes)
    {
        <div style="border: 1px solid #ccc; padding: 12px; margin-bottom: 12px; border-radius: 8px;">
            <h3>@note.Title</h3>
            <p><strong>Category:</strong> @note.Category</p>
            <p>@note.Content</p>
            <p><small>Created at: @note.CreatedAt.ToLocalTime()</small></p>

            <button @onclick="() => DeleteNoteAsync(note.Id)">Delete</button>
        </div>
    }
}

@code {
    private List<DeploymentNoteDto> notes = new();
    private CreateDeploymentNoteDto newNote = new();
    private bool isLoading = true;
    private string? errorMessage;
private HealthStatusDto? healthStatus;

    protected override async Task OnInitializedAsync()
    {
await LoadHealthStatusAsync();
        await LoadNotesAsync();
    }
private async Task LoadHealthStatusAsync()
{
    try
    {
        healthStatus = await HealthApiClient.GetHealthAsync();
    }
    catch
    {
        healthStatus = new HealthStatusDto
        {
            Status = "Unreachable",
            Database = "Unknown",
            Environment = "Unknown",
            Timestamp = DateTime.UtcNow
        };
    }
}
    private async Task LoadNotesAsync()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            notes = await NotesApiClient.GetNotesAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not load notes. Is the API running? Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CreateNoteAsync()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(newNote.Title) ||
            string.IsNullOrWhiteSpace(newNote.Category) ||
            string.IsNullOrWhiteSpace(newNote.Content))
        {
            errorMessage = "Please fill in title, category and content.";
            return;
        }

        var createdNote = await NotesApiClient.CreateNoteAsync(newNote);

        if (createdNote is null)
        {
            errorMessage = "Could not create note.";
            return;
        }

        newNote = new CreateDeploymentNoteDto();
        await LoadNotesAsync();
    }

    private async Task DeleteNoteAsync(int id)
    {
        try
        {
            await NotesApiClient.DeleteNoteAsync(id);
            await LoadNotesAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not delete note. Error: {ex.Message}";
        }
    }
}