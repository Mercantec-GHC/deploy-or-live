@page "/"
@using DomainModels.Dto
@using DomainModels.Models
@using Blazor.Components

<PageTitle>DoDLJ</PageTitle>

<div class="documentation-page">
    @* Hero / intro section *@
    <section class="journey-hero">
        <div class="journey-hero-content">
            <p class="journey-eyebrow">Deployment learning portfolio</p>
            <h1 class="journey-title">DoDLJ. Victoria's Deployment Journey</h1>
            <div class="journey-subtitle">
                <p>Documentation report of a 3-week deployment and DevOps course "Deploy or Die", including implementation notes,
                infrastructure decisions, troubleshooting, and learning reflections.
                </p>
                <p>Student: <span class="nested-text">Victoria Wivelsted</span></p>
                <p>School: <span class="nested-text">Mercantec</span></p>
                <p>Course: <span class="nested-text">Deploy or Die</span></p>
                <p>Date: <span class="nested-text">25.06.2026</span></p>
                <p>Teachers: <span class="nested-text">Mathias Gaarsdal Steenberg, Paw Dahl Andersen, Jakob Kjartansson</span></p>
                <p>Repository link: <span class="nested-text"><a href="https://github.com/Mercantec-GHC/deploy-or-live" target="_blank">GitHub</a></span></p>
                <p>Live URL: <span class="nested-text"><a href="https://victoria.mercantec.tech" target="_blank">https://victoria.mercantec.tech</a></span></p>
            </div>
            <div class="journey-badges">
                <span class="journey-badge">Blazor WebAssembly (.NET8)</span>
                <span class="journey-badge">ASP.NET Core Web API (.NET8)</span>
                <span class="journey-badge">MS SQL Server</span>
                <span class="journey-badge">Nginx</span>
                <span class="journey-badge">Cloudflare DNS</span>
                <span class="journey-badge">Docker</span>
                <span class="journey-badge">Docker Compose</span>
                <span class="journey-badge">VM (Ubuntu Server)</span>
                <span class="journey-badge">SSH</span>
                <span class="journey-badge">GitHub</span>
                <span class="journey-badge">GitHub Actions</span>
                <span class="journey-badge">Dokploy</span>
            </div>
        </div>
    </section>

    @* API/database health status and edit mode controls *@
    <section class="journey-status-strip">
        <div class="journey-status-content">
            @if (healthStatus is null)
            {
                <div class="journey-health-list">
                    <span class="journey-health-pill">API: Checking...</span>
                    <span class="journey-health-pill">Database: Checking...</span>
                </div>
            }
            else
            {
                var apiHealthy = !string.IsNullOrWhiteSpace(healthStatus.Status) && healthStatus.Status.Contains("healthy", StringComparison.OrdinalIgnoreCase);
                var dbHealthy = !string.IsNullOrWhiteSpace(healthStatus.Database)
                    && (healthStatus.Database.Contains("healthy", StringComparison.OrdinalIgnoreCase)
                        || healthStatus.Database.Contains("connected", StringComparison.OrdinalIgnoreCase));
                <div class="journey-health-list">
                    <span class="journey-health-pill @(apiHealthy ? "is-healthy" : "is-unhealthy")">API: @healthStatus.Status</span>
                    <span class="journey-health-pill @(dbHealthy ? "is-healthy" : "is-unhealthy")">Database: @healthStatus.Database</span>
                    <span class="journey-health-pill">Environment: @healthStatus.Environment</span>
                    <span class="journey-health-pill">Checked: @healthStatus.Timestamp.ToLocalTime().ToString("g")</span>
                </div>
            }

            <label class="journey-edit-toggle">
                <input type="checkbox" @bind="isEditMode" disabled="@string.IsNullOrWhiteSpace(editApiKey)" />
                <span>Edit mode</span>
            </label>

            <input type="password"
                   class="form-control"
                   style="max-width: 220px;"
                   placeholder="Enter edit key"
                   @bind="editApiKey" />
        </div>
    </section>

    @* Error message shown when API calls fail *@
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="journey-alert" role="alert">@errorMessage</div>
    }

    @* Small report summary cards *@
    <section class="journey-snapshot-grid">
        <article class="snapshot-card">
            <p class="snapshot-label">Milestones</p>
            <p class="snapshot-value">@milestones.Count</p>
            <p class="snapshot-hint">Documentation chapters</p>
        </article>
        <article class="snapshot-card">
            <p class="snapshot-label">Total Characters</p>
            <p class="snapshot-value">@TotalCharacterCount()</p>
            <p class="snapshot-hint">Spaces included</p>
        </article>
        <article class="snapshot-card">
            <p class="snapshot-label">Last updated</p>
            <p class="snapshot-value snapshot-value-date">@(milestones.Count == 0 ? "-" : milestones.Max(m => m.UpdatedAt).ToLocalTime().ToString("dd MMM"))</p>
            <p class="snapshot-hint">Most recent change</p>
        </article>
    </section>

    @* Course skills checklist *@
    <section class="skills-section">
        <div class="skills-header">
            <h2 class="skills-title">Skills Gained</h2>
            <p class="skills-subtitle">An overview of the topics covered during the course.</p>
        </div>
        <ul class="skills-checklist">
            @foreach (var skill in CourseSkills.All)
            {
                <li class="skill-item @(skill.IsAchieved ? "is-achieved" : "is-not-achieved")">
                    <input type="checkbox" checked="@skill.IsAchieved" disabled />
                    <span class="skill-name">@skill.Name</span>
                </li>
            }
        </ul>
    </section>

    @* Main documentation report layout *@
    <section class="documentation-report-layout">
        @* Table of contents generated from milestones *@
        <aside class="toc-panel">
            <h2>Table of Contents</h2>
            @if (milestones.Count == 0)
            {
                <p class="toc-empty">No milestones loaded.</p>
            }
            else
            {
                <ul class="toc-list">
                    @for (var i = 0; i < milestones.Count; i++)
                    {
                        var milestone = milestones[i];
                        <li>
                            <a href="#milestone-@milestone.Category">
                                @((i + 1).ToString("D2")) @milestone.CategoryDisplayName
                            </a>
                        </li>
                    }
                </ul>
            }
        </aside>

        @* Documentation milestone cards *@
        <div class="report-sections">
            @for (var i = 0; i < milestones.Count; i++)
            {
                var milestone = milestones[i];
                var themeClass = GetThemeClass(i);

                <article class="report-section-card @themeClass" id="milestone-@milestone.Category">
                    <header class="report-section-header">
                        <div class="report-section-title-wrap">
                            <span class="report-section-index">@((i + 1).ToString("D2"))</span>
                            <div>
                               <h3>@milestone.CategoryDisplayName</h3>                               
                            </div>
                        </div>

                        @if (isEditMode && editingMilestone?.Category != milestone.Category)
                        {
                            <button class="btn btn-outline-secondary report-edit-button"
                                    @onclick="() => StartEditingMilestone(milestone)">
                                Edit section
                            </button>
                        }
                    </header>

                    @* Edit form for the selected milestone *@
                    @if (isEditMode && editingMilestone?.Category == milestone.Category)
                    {
                        <div class="milestone-edit-form">
                            <label class="edit-label">Section title</label>
                            <input class="form-control"
                                   @bind="editModel.CategoryDisplayName" />

                            <label class="edit-label">Documentation content</label>
                            <textarea class="form-control documentation-editor"
                                      @bind="editModel.DocumentationContent"></textarea>

                            <div class="edit-actions">
                                <button class="btn btn-primary" @onclick="SaveMilestoneAsync">Save</button>
                                <button class="btn btn-secondary" @onclick="CancelEditingMilestone">Cancel</button>
                            </div>
                        </div>
                    }
                    else
                    {
                        @* Read-only milestone content and implementation screens *@
                        <div class="report-section-body">
                            @if (string.IsNullOrWhiteSpace(milestone.DocumentationContent))
                            {
                                <p class="milestone-placeholder">Documentation for this milestone has not been added yet.</p>
                            }
                            else
                            {
                                <p class="milestone-documentation">@milestone.DocumentationContent</p>
                            }

                            <ImplementationScreen Items="GetImplementationScreensFor(milestone.Category)"
                                                  CategoryDisplayName="@milestone.CategoryDisplayName" />

                            <p class="milestone-character-count">Character count: @CountCharacters(milestone)</p>
                        </div>
                    }
                </article>
            }
        </div>
    </section>
</div>
