@page "/"
@using DomainModels.Dto
@using DomainModels.Models
@using Blazor.Interfaces
@using Blazor.Helpers
@inject IHealthApiClient HealthApiClient
@inject IDocumentationApiClient DocumentationApiClient

<!-- HERO SECTION -->
<section class="hero-section">
    <div class="hero-content">
        <h1 class="hero-title">Hi! I'm Victoria and this is my experience in how I used 3 weeks on learning about deployment</h1>
        <p class="hero-subtitle">A full-stack deployment learning project with Blazor, ASP.NET Core, EF Core and SQL Server.</p>
        <div class="hero-badges">
            <span class="badge-tech">Blazor WASM</span>
            <span class="badge-tech">ASP.NET Core API</span>
            <span class="badge-tech">EF Core</span>
            <span class="badge-tech">SQL Server</span>
            <span class="badge-tech">Docker-ready</span>
        </div>
    </div>
</section>

<!-- PROJECT STATUS BAR -->
<section class="status-bar">
    <div class="status-container">
        @if (healthStatus is null)
        {
            <div class="status-item">
                <span class="status-label">Backend Status:</span>
                <span class="status-value checking">Checking...</span>
            </div>
        }
        else
        {
            var healthy = !string.IsNullOrWhiteSpace(healthStatus.Status) && healthStatus.Status.Contains("healthy", StringComparison.OrdinalIgnoreCase);
            <div class="status-item">
                <span class="status-label">Backend:</span>
                <span class="status-value @(healthy ? "healthy" : "unreachable")">@healthStatus.Status</span>
            </div>
            <div class="status-item">
                <span class="status-label">Database:</span>
                <span class="status-value @(healthy ? "healthy" : "unreachable")">@healthStatus.Database</span>
            </div>
            <div class="status-item">
                <span class="status-label">Environment:</span>
                <span class="status-value">@healthStatus.Environment</span>
            </div>
            <div class="status-item">
                <span class="status-label">Checked:</span>
                <span class="status-value">@healthStatus.Timestamp.ToLocalTime().ToString("g")</span>
            </div>
        }

        <div class="status-edit-mode">
            <!-- Temporary UI-only edit mode. Real protection must be implemented in the API with authentication/authorization. -->
            <label class="edit-mode-label">
                <input type="checkbox" @bind="isEditMode" />
                <span>Edit mode</span>
            </label>
        </div>
    </div>
</section>

<!-- DOCUMENTATION INTRODUCTION -->
<section class="doc-section intro-section">
    <h2>About This Documentation</h2>
    <p>
        This page documents my journey of learning real-world deployment over 3 weeks. Each section below covers a key topic from the DevOps course, 
        including what I did, commands I executed, problems I encountered, and what I learned. At the end, you'll find evidence of deployment and a final reflection.
    </p>
    <p class="requirement-note">
        <strong>Documentation Target:</strong> At least 14,400 characters, including terminal commands, screenshots, reflections and deployment proof.
    </p>
</section>

<!-- PROGRESS SECTION -->
<section class="doc-section progress-section">
    <h2>Documentation Progress</h2>
    <div class="progress-items">
        <div class="progress-item">
            <div class="progress-label">Written Documentation</div>
            <div class="progress-bar">
                <div class="progress-fill" style="width: 0%;"></div>
            </div>
        </div>
        <div class="progress-item">
            <div class="progress-label">Commands</div>
            <div class="progress-bar">
                <div class="progress-fill" style="width: 0%;"></div>
            </div>
        </div>
        <div class="progress-item">
            <div class="progress-label">Screenshots</div>
            <div class="progress-bar">
                <div class="progress-fill" style="width: 0%;"></div>
            </div>
        </div>
        <div class="progress-item">
            <div class="progress-label">Reflections</div>
            <div class="progress-bar">
                <div class="progress-fill" style="width: 0%;"></div>
            </div>
        </div>
        <div class="progress-item">
            <div class="progress-label">Deployment Proof</div>
            <div class="progress-bar">
                <div class="progress-fill" style="width: 0%;"></div>
            </div>
        </div>
    </div>
</section>

<!-- MILESTONE SECTIONS -->
<section class="milestones-container">
    <div class="accordion" id="milestonesAccordion">
        @foreach (var milestone in milestones)
        {
            var categoryName = milestone.CategoryDisplayName;
			var categoryKey = milestone.Category.ToString();

            <div class="milestone-content">
                @if (string.IsNullOrWhiteSpace(milestone.DocumentationContent))
                {
                    <p class="placeholder-text">
                        Placeholder: Add documentation content for this milestone.
                    </p>
                }
                else
                {
                    <p>@milestone.DocumentationContent</p>
                }
            </div>
            @if (isEditMode && editingMilestone?.Id == milestone.Id)
            {
                <div class="milestone-edit-form">
                    <label>Section title</label>
                    <input class="form-control"
                           @bind="editModel.CategoryDisplayName" />

                    <label>Documentation content</label>
                    <textarea class="form-control documentation-editor"
                              @bind="editModel.DocumentationContent"></textarea>

                    <div class="edit-actions">
                        <button class="btn btn-primary" @onclick="SaveMilestoneAsync">
                            Save
                        </button>

                        <button class="btn btn-secondary" @onclick="CancelEditingMilestone">
                            Cancel
                        </button>
                    </div>
                </div>
            }
            else
            {
                <h2>@milestone.CategoryDisplayName</h2>

                <div class="milestone-content">
                    @if (string.IsNullOrWhiteSpace(milestone.DocumentationContent))
                    {
                        <p class="placeholder-text">
                            Placeholder: Add documentation content for this milestone.
                        </p>
                    }
                    else
                    {
                        <p>@milestone.DocumentationContent</p>
                    }
                </div>

                @if (isEditMode)
                {
                    <button class="btn btn-outline-primary"
                            @onclick="() => StartEditingMilestone(milestone)">
                        Edit section
                    </button>
                }
            }
        }
    </div>
</section>



@code {
    private List<DocumentationMilestoneDto> milestones = new();
    private bool isLoading = true;
    private string? errorMessage;
    private HealthStatusDto? healthStatus;
    private DocumentationMilestoneDto? editingMilestone;
    private UpdateDocumentationMilestoneDto editModel = new();

    private bool isEditMode = false;
    private bool showEditForm = false;
    private string selectedCategoryDisplay = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadHealthStatusAsync();
        await LoadMilestonesAsync();
    }

    private async Task LoadHealthStatusAsync()
    {
        try
        {
            healthStatus = await HealthApiClient.GetHealthAsync();
        }
        catch
        {
            healthStatus = new HealthStatusDto
            {
                Status = "Unreachable",
                Database = "Unknown",
                Environment = "Unknown",
                Timestamp = DateTime.UtcNow
            };
        }
    }   

    private async Task LoadMilestonesAsync()
    {
        try
        {
            milestones = await DocumentationApiClient.GetMilestonesAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not load documentation milestones. Is the API running? Error: {ex.Message}";
        }
    }
    private void StartEditingMilestone(DocumentationMilestoneDto milestone)
    {
        editingMilestone = milestone;

        editModel = new UpdateDocumentationMilestoneDto
        {
            CategoryDisplayName = milestone.CategoryDisplayName,
            DocumentationContent = milestone.DocumentationContent
        };
    }

    private void CancelEditingMilestone()
    {
        editingMilestone = null;
        editModel = new UpdateDocumentationMilestoneDto();
    }

    private async Task SaveMilestoneAsync()
    {
        if (editingMilestone is null)
        {
            return;
        }

        var updatedMilestone = await DocumentationApiClient.UpdateMilestoneAsync(
            editingMilestone.Category,
            editModel);

        if (updatedMilestone is null)
        {
            errorMessage = "Could not update documentation milestone.";
            return;
        }

        var index = milestones.FindIndex(milestone => milestone.Id == updatedMilestone.Id);

        if (index >= 0)
        {
            milestones[index] = updatedMilestone;
        }

        editingMilestone = null;
        editModel = new UpdateDocumentationMilestoneDto();
    }

    private void ToggleEditForm()
    {
        showEditForm = !showEditForm;
    }
}
